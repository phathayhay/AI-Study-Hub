# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_CLOUD_PROJECT_ID=projects/your_project_id
GEMINI_MODEL=gemini-2.5-flash

# Cloudinary (lưu trữ file)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Cấu hình gửi email (Gmail App Password)
# B1: Bật chế độ Xác minh 2 bước
# B2: Truy cập https://myaccount.google.com/apppasswords
# B3: Tạo App Password cho dự án AI Study Hub (16 ký tự)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password
