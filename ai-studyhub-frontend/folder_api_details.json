  "folderEndpointsDetail": {
    "/api/folders/{id}": {
      "get": {
        "tags": [
          "Folder Management"
        ],
        "summary": "Get folder details",
        "description": "Retrieves details of a folder and its children by its unique folder ID.",
        "operationId": "getFolderDetails",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Folder details retrieved successfully",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/FolderResponse"
                }
              }
            }
          },
          "401": {
            "description": "User is not logged in / Invalid access token",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                },
                "example": {
                  "success": false,
                  "message": "User is not logged in / Invalid access token",
                  "timestamp": "2026-06-14T16:40:00"
                }
              }
            }
          },
          "404": {
            "description": "Folder not found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ApiErrorResponse"
                },
                "example": {
                  "success": false,
                  "message": "Folder not found",
                  "timestamp": "2026-06-14T16:40:00"
                }
              }
            }
          },
          "500": {
